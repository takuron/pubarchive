<%
if (!page.tag) {
  page.title = 'Tags';
} else {
  page.title = 'Tag: ' + page.tag;
}
%>

<!-- Tags index: show all tags -->
<% if (!page.tag) { %>
<div class="tag-cloud">
  <div class="page-title">Tags</div>
  <% if (site.tags.length) { %>
  <ul class="tag-list">
    <% site.tags.each(function (tag) { %>
    <li class="tag-item">
      <a class="tag-name" href="<%- url_for(tag.path) %>">
        <%- tag.name %>
      </a>
      <span class="tag-count"><%- tag.posts.length %></span>
    </li>
    <% }) %>
  </ul>
  <% } else { %>
  <p class="empty">No tags yet.</p>
  <% } %>
</div>

<!-- Specific tag: show posts for this tag -->
<% } else { %>
<div class="tag-header">
  <div class="page-title">Tag: <%- page.tag %></div>
</div>
<ul class="archives">
  <% page.posts.each(function (post) { %>
  <li class="archive-item">
    <span class="date"><%= date(post.date, "YYYY.MM.DD") %></span>
    <a class="title" href="<%- url_for(post.path) %>"><%= post.title %></a>
    <% if (post.source_url) { %>
    <span class="source"><a href="<%- post.source_url %>" target="_blank" rel="noopener noreferrer">view source</a></span>
    <% } %>
  </li>
  <% }) %>
</ul>

<%- partial('_partial/paginator') %>
<% } %>
